package FocusFlow;
import java.util.Scanner;
public class SummaryGenerator   {

    String[] historySubject = new String[50];
    String[] historyDate = new String[50];
    int[] historyMinutes = new int[50];
    int historyCount = 0;

    public void addHistoryManual() {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Subject: ");
        historySubject[historyCount] = sc.nextLine();

        System.out.print("Enter Date (YYYY-MM-DD): ");
        historyDate[historyCount] = sc.nextLine();

        System.out.print("Enter Minutes Studied: ");
        historyMinutes[historyCount] = sc.nextInt();
        sc.nextLine();

        historyCount++;

        System.out.println("History added!");
    }

    public void searchHistory() {
        Scanner sc = new Scanner(System.in);

        if (historyCount == 0) {
            System.out.println("No study history yet.");
            return;
        }

        System.out.print("Search by subject or date: ");
        String input = sc.nextLine().toLowerCase();

        boolean found = false;

        System.out.println("\n--- RESULT ---");
        for (int i = 0; i < historyCount; i++) {
            if (historySubject[i].toLowerCase().contains(input) ||
                    historyDate[i].contains(input)) {

                System.out.println(historySubject[i] + " | " +
                        historyDate[i] + " | " +
                        historyMinutes[i] + " mins");
                found = true;
            }
        }

        if (!found) {
            System.out.println("No match found.");
        }
    }

    public void dailySummary() {
        Scanner sc = new Scanner(System.in);

        if (historyCount == 0) {
            System.out.println("No study history yet.");
            return;
        }

        System.out.print("Enter date (YYYY-MM-DD): ");
        String date = sc.nextLine();

        int total = 0;
        int sessions = 0;
        String topSubject = "";
        int max = 0;

        for (int i = 0; i < historyCount; i++) {
            if (historyDate[i].equals(date)) {
                total += historyMinutes[i];
                sessions++;

                if (historyMinutes[i] > max) {
                    max = historyMinutes[i];
                    topSubject = historySubject[i];
                }
            }
        }

        System.out.println("\n--- DAILY SUMMARY ---");
        System.out.println("Date: " + date);
        System.out.println("Total Minutes: " + total);
        System.out.println("Sessions: " + sessions);
        System.out.println("Top Subject: " + topSubject);
    }
    
    public void weeklySummary() {
        Scanner sc = new Scanner(System.in);

        if (historyCount == 0) {
            System.out.println("No study history yet.");
            return;
        }

        System.out.print("Enter start date (YYYY-MM-DD): ");
        String start = sc.nextLine();

        System.out.print("Enter end date (YYYY-MM-DD): ");
        String end = sc.nextLine();

        int total = 0;

        for (int i = 0; i < historyCount; i++) {
            if (historyDate[i].compareTo(start) >= 0 &&
                    historyDate[i].compareTo(end) <= 0) {

                total += historyMinutes[i];
            }
        }

        System.out.println("\n--- WEEKLY SUMMARY ---");
        System.out.println("From " + start + " to " + end);
        System.out.println("Total Minutes: " + total);
    }
}
